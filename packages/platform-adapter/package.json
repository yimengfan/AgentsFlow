{
  "name": "@agentsflow/platform-adapter",
  "version": "0.1.0",
  "description": "Platform adapter — abstracts IPC (Electron) vs HTTP (Web) backends",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@agentsflow/shared-contracts": "workspace:*"
  },
  "devDependencies": {
    "react": "^19.0.0",
    "@types/react": "^19.2.14"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "license": "MIT"
}