{
  "name": "@agentsflow/prompt-asset-resolver",
  "version": "0.1.0",
  "description": "Scans .agents-flow/ directory, parses frontmatter, resolves prompt assets, and assembles provider prompt packages",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@agentsflow/flow-schema": "workspace:*",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "keywords": ["agentsflow", "prompt", "asset", "resolver", "agents-flow"]
}
