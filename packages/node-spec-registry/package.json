{
  "name": "@agentsflow/node-spec-registry",
  "version": "0.1.0",
  "description": "Node specification registry for AgentsFlow — defines node kinds, ports, parameters, and categories",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentsflow/flow-schema": "workspace:*"
  },
  "license": "MIT",
  "keywords": ["agentsflow", "node", "spec", "registry"]
}