{
  "name": "@agentsflow/agent-registry",
  "version": "0.1.0",
  "description": "Adapter discovery, registration, capability metadata, and compatibility checking",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@agentsflow/agent-contracts": "workspace:*",
    "@agentsflow/shared-contracts": "workspace:*"
  },
  "license": "MIT",
  "keywords": ["agentsflow", "agent", "registry", "adapter"]
}
