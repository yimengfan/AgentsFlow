{
  "name": "@agentsflow/agent-contracts",
  "version": "0.1.0",
  "description": "Agent-neutral abstract interfaces for the AgentsFlow platform",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "keywords": ["agentsflow", "agent", "contracts", "adapter"]
}
